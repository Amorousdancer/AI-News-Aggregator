# Database
DATABASE_URL=postgresql+asyncpg://aggregator:aggregator@localhost:5432/news_aggregator

# Anthropic (primary LLM)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional fallback)
OPENAI_API_KEY=sk-...

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development

# Rate limits
MAX_CONCURRENT_FETCHES=5
DEFAULT_FETCH_INTERVAL_MINUTES=30
ANALYSIS_BATCH_SIZE=50
DAILY_COST_LIMIT_USD=20.00

# Retention
ARTICLE_RETENTION_DAYS=90
